{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Notch",
  "version": "0.1.0",
  "identifier": "us.czekaj.hermes-notch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "width": 420,
        "height": 36,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "focus": false,
        "acceptFirstMouse": true,
        "visible": false,
        "theme": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns", "icons/128x128.png", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
